# ══════════════════════════════════════════════════════════════
# SOVEREIGN — Production Environment Variables
# ══════════════════════════════════════════════════════════════
# These values are set in Railway (backend) and Vercel (frontend).
# This file documents the exact variable names and expected shapes.
# Do NOT commit real values.
# See docs/ENVIRONMENT_MATRIX.md for the full contract.
# ══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
AUTH_MODE=workos
APP_ENV=production
APP_BASE_URL=https://app.sovereign.app
API_BASE_URL=https://api.sovereign.app
CORS_ALLOWED_ORIGINS=https://app.sovereign.app

# ─── Database (Railway Postgres) ─────────────────────────────
# Auto-provided by Railway Postgres addon
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ─── Redis (Railway Redis) ───────────────────────────────────
# Auto-provided by Railway Redis addon
# Format: redis://default:password@host:port
REDIS_URL=

# ─── Auth (WorkOS) ───────────────────────────────────────────
# Get from: WorkOS Dashboard → API Keys
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=https://api.sovereign.app/api/v1/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=https://app.sovereign.app
WORKOS_LOGIN_ENDPOINT=/api/v1/auth/login
# Generate: openssl rand -base64 48
SESSION_SECRET=

# ─── Temporal ─────────────────────────────────────────────────
# Temporal Cloud: <namespace>.tmprl.cloud:7233
# Railway-hosted: temporal.railway.internal:7233
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=sovereign-production
# mTLS (Temporal Cloud only) — base64-encoded
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=

# ─── Object Storage (Cloudflare R2) ──────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_BUCKET=sovereign-production-artifacts
R2_REGION=auto
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── AI Runtime (OpenAI) ─────────────────────────────────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=

# ─── Credential Encryption ───────────────────────────────────
# Generate: openssl rand -base64 48
# CRITICAL: Back up securely. Loss = unrecoverable encrypted credentials.
SOVEREIGN_SECRET_KEY=

# ─── Billing (Stripe) ────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=

# ─── CI/CD Tokens (set in GitHub Secrets, NOT here) ──────────
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID_WEB_PRODUCTION
# VERCEL_PROJECT_ID_DOCS_PRODUCTION
# RAILWAY_TOKEN
