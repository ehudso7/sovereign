# ══════════════════════════════════════════════════════════════
# SOVEREIGN — Production Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file and set ALL values. No defaults are safe for production.
# See DEPLOY.md for how to obtain each value.
# ══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Database (Neon) ──────────────────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
# Get from: Neon Console → Project → Connection Details → Connection String
# IMPORTANT: Use the POOLED connection string (port 5432) for the API
# Use the DIRECT connection string (port 5433) for migrations only
DATABASE_URL=
DATABASE_URL_DIRECT=

# ─── Redis (Upstash) ─────────────────────────────────────────
# Format: rediss://default:password@host:port
# Get from: Upstash Console → Database → REST API → Redis URL
# NOTE: uses rediss:// (with double s) for TLS
REDIS_URL=

# ─── Auth (WorkOS) ───────────────────────────────────────────
# Get from: WorkOS Dashboard → API Keys
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ─── Session ─────────────────────────────────────────────────
# Generate: openssl rand -base64 48
SESSION_SECRET=

# ─── Temporal (Temporal Cloud) ───────────────────────────────
# Format: <namespace>.tmprl.cloud:7233
# Get from: Temporal Cloud → Namespaces → Connection info
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
# mTLS certificates for Temporal Cloud
# Get from: Temporal Cloud → Namespaces → Certificates
# Store as base64-encoded: cat cert.pem | base64 -w0
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=

# ─── Object Storage (Cloudflare R2) ──────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
S3_BUCKET=sovereign-prod
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── AI Runtime (OpenAI) ─────────────────────────────────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=

# ─── Credential Encryption ───────────────────────────────────
# Generate: openssl rand -base64 48
# CRITICAL: If you lose this key, ALL encrypted connector credentials are unrecoverable
SOVEREIGN_SECRET_KEY=

# ─── Billing (Stripe) ────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=

# ─── Vercel (CI/CD only — set in GitHub Secrets) ─────────────
# VERCEL_TOKEN=          # vercel.com → Settings → Tokens
# VERCEL_ORG_ID=         # vercel.com → Settings → General → Team ID
# VERCEL_WEB_PROJECT_ID= # vercel.com → Project → Settings → General → Project ID
# VERCEL_DOCS_PROJECT_ID=# Same, for docs project

# ─── Railway (CI/CD only — set in GitHub Secrets) ────────────
# RAILWAY_TOKEN=         # railway.app → Account → Tokens
