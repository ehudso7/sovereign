# ══════════════════════════════════════════════════════════════
# SOVEREIGN — Local Development Environment
# ══════════════════════════════════════════════════════════════
# Copy to .env and adjust as needed. Start infra:
#   cd infra/docker && docker compose up -d
# ══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
AUTH_MODE=local
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3002

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://sovereign:sovereign_dev@localhost:5432/sovereign

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (WorkOS) ───────────────────────────────────────────
# Only needed if AUTH_MODE=workos
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=http://localhost:3000
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# ─── Temporal ─────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=sovereign

# ─── Object Storage (MinIO for local dev, R2-compatible) ─────
R2_BUCKET=sovereign-dev
R2_REGION=us-east-1
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=sovereign
R2_SECRET_ACCESS_KEY=sovereign_dev

# ─── AI Runtime (OpenAI) ─────────────────────────────────────
OPENAI_API_KEY=

# ─── Credential Encryption ───────────────────────────────────
SOVEREIGN_SECRET_KEY=change-me-to-a-real-secret-key-at-least-32-chars

# ─── Billing (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
