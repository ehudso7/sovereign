# Application
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://sovereign:sovereign_dev@localhost:5432/sovereign

# Redis
REDIS_URL=redis://localhost:6379

# Auth (WorkOS)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=sovereign

# Object Storage (MinIO for local dev)
S3_BUCKET=sovereign-dev
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=sovereign
S3_SECRET_ACCESS_KEY=sovereign_dev

# OpenAI
OPENAI_API_KEY=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
