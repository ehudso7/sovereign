{
  "name": "@sovereign/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts --exclude 'src/__tests__/e2e/**' --exclude 'src/__tests__/load/**' --exclude 'src/__tests__/resilience/**'",
    "test:e2e": "vitest run --config vitest.config.ts src/__tests__/e2e/ src/__tests__/load/ src/__tests__/resilience/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@fastify/rate-limit": "^10.0.0",
    "@sovereign/config": "workspace:*",
    "@sovereign/core": "workspace:*",
    "@sovereign/db": "workspace:*",
    "@sovereign/gateway-mcp": "workspace:*",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
