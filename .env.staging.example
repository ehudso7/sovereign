# ══════════════════════════════════════════════════════════════
# SOVEREIGN — Staging Environment Variables
# ══════════════════════════════════════════════════════════════
# These values are set in Railway (backend) and Vercel (frontend).
# This file documents the exact variable names and expected shapes.
# Do NOT commit real values.
# See docs/ENVIRONMENT_MATRIX.md for the full contract.
# ══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
AUTH_MODE=workos
APP_ENV=staging
APP_BASE_URL=https://staging.sovereign.app
API_BASE_URL=https://api-staging.sovereign.app
CORS_ALLOWED_ORIGINS=https://staging.sovereign.app

# ─── Database (Railway Postgres) ─────────────────────────────
# Auto-provided by Railway Postgres addon
DATABASE_URL=

# ─── Redis (Railway Redis) ───────────────────────────────────
# Auto-provided by Railway Redis addon
REDIS_URL=

# ─── Auth (WorkOS) ───────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=https://staging.sovereign.app/api/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=https://staging.sovereign.app
WORKOS_LOGIN_ENDPOINT=/api/v1/auth/login
SESSION_SECRET=

# ─── Temporal ─────────────────────────────────────────────────
# Temporal Cloud: <namespace>.tmprl.cloud:7233
# Railway-hosted: temporal.railway.internal:7233
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=sovereign-staging

# ─── Object Storage (Cloudflare R2) ──────────────────────────
R2_BUCKET=sovereign-staging-artifacts
R2_REGION=auto
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── AI Runtime (OpenAI) ─────────────────────────────────────
OPENAI_API_KEY=

# ─── Credential Encryption ───────────────────────────────────
# Generate: openssl rand -base64 48
# CRITICAL: Back up securely. Loss = unrecoverable encrypted credentials.
SOVEREIGN_SECRET_KEY=

# ─── Billing (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
